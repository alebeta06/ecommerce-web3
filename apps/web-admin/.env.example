# web-admin — environment variables (template, NO secrets here)
# 🇪🇸 NOTA: Copia a `.env.local` y rellena. Las NEXT_PUBLIC_* se exponen al navegador (no
# secretas); PINATA_JWT es secreto (solo servidor). `.env.local` está gitignored.

# ── Blockchain (Anvil local) ────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=http://localhost:8545
NEXT_PUBLIC_CHAIN_ID=31337
# 🇪🇸 Addresses del despliegue. En Anvil (cuenta 0, nonces 0 y 1) son deterministas:
#   EuroToken = 0x5FbDB2315678afecb367f032d93F642f64180aa3
#   Ecommerce = 0xe7f1725E7734CE288F8367e1Bb143E90bb3F0512
NEXT_PUBLIC_EURO_TOKEN_ADDRESS=
NEXT_PUBLIC_ECOMMERCE_ADDRESS=

# ── IPFS (Pinata) ───────────────────────────────────────────────────────
PINATA_JWT=                                   # server-side, for uploads
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/   # public read gateway
