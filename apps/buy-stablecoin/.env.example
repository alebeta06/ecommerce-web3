# buy-stablecoin — environment variables (template, NO secrets here)
# 🇪🇸 NOTA: Copia este archivo a `.env` y rellena los valores. El `.env` real NO se versiona.
#          Las variables NEXT_PUBLIC_* se exponen al navegador; las demás son SOLO de servidor.

# ── On-chain ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_RPC_URL=http://localhost:8545
NEXT_PUBLIC_EURO_TOKEN_ADDRESS=

# ── Stripe ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx   # client-side (publishable) key
STRIPE_SECRET_KEY=sk_test_xxx                    # server-side secret key
STRIPE_WEBHOOK_SECRET=whsec_xxx                  # to verify webhook signatures

# ── Minter wallet (server-side, owner of EuroToken) ─────────────────────────
MINTER_PRIVATE_KEY=                              # wallet allowed to call mint()
